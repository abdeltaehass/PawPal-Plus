%% PawPal+ — UML Class Diagram (Phase 1 draft)
%% Preview in VS Code (Mermaid extension) or https://mermaid.live
classDiagram
    direction LR

    class Owner {
        +str name
        +str email
        +List~Pet~ pets
        +add_pet(pet) None
        +remove_pet(name) None
        +get_pet(name) Pet
        +all_tasks() List~Task~
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +str notes
        +List~Task~ tasks
        +add_task(task) None
        +remove_task(task_id) None
        +get_tasks() List~Task~
    }

    class Task {
        +int task_id
        +str title
        +TaskType task_type
        +datetime due
        +int duration_minutes
        +Priority priority
        +Recurrence recurrence
        +bool completed
        +mark_complete() None
        +is_due_on(day) bool
        +end_time() datetime
        +overlaps_with(other) bool
        +next_occurrence() Task
    }

    class Scheduler {
        +List~Task~ tasks
        +add_task(task) None
        +sort_by_priority() List~Task~
        +sort_by_time() List~Task~
        +tasks_for_day(day) List~Task~
        +today() List~Task~
        +upcoming(days) List~Task~
        +detect_conflicts() List~Conflict~
        +expand_recurring(until) List~Task~
    }

    class TaskType {
        <<enumeration>>
        FEEDING
        WALK
        MEDICATION
        APPOINTMENT
        GROOMING
        OTHER
    }

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
        CRITICAL
    }

    class Recurrence {
        <<enumeration>>
        NONE
        DAILY
        WEEKLY
        MONTHLY
    }

    Owner "1" o-- "0..*" Pet : owns
    Pet "1" o-- "0..*" Task : has
    Scheduler "1" o-- "0..*" Task : manages
    Task ..> TaskType : uses
    Task ..> Priority : uses
    Task ..> Recurrence : uses
